{
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "ΎΒς",
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "pulseaudio": {
        "format": "Sound:  {volume}%",
        "format-bluetooth": "{icon} {volume}% ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "Όα╕ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "ΎΘτ   {essid} ({signalStrength}%)",
        "format-ethernet": "{ipaddr}/{cidr} ≤░ΙΑ",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP) έγι",
        "format-disconnected": "Disconnected έγι",
	"on-click": "sh ~/scripts/rofi-wifi-menu/rofi-wifi-menu.sh"
	 
    },
    "cpu": {
        "format": "ΎΜδ  {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "ΎΔΚ  {}%",
	"tooltip": true
    },
    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon1/temp1_input",
        "critical-threshold": 100,
        "format-critical": "ΎΜΘ {temperatureC}",
        "format": "ΎΜΚ {temperatureC}┬░C"
    },
    "hyprland/language": {
       "format": "ΎΓυ  {}",
       "format-en": "EN",
       "format-pl": "PL"
    },
    "clock": {
        "format": "{:%H:%M | %e %B} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    }

}