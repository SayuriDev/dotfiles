{
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format-icons": {
      "active": "",
      "urgent": "",
      "default": ""
    }
  },
  "hyprland/window": {
    "max-length": 40
  },
  "pulseaudio": {
    "format": " {volume}%",
    "format-bluetooth": "󰦢  {volume}%",
    "format-muted": " MUTED",
    "justify": "center",
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },
  "pulseaudio#mic": {
    "format": "󰍬 {format_source}",
    "format-source": "{volume}%",
    "format-source-muted": "MUTED",
    "on-click": "pavucontrol -t 4",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%-",
    "tooltip": false
},
  "tray": {
    "icon-size": 17,
    "spacing": 6
  },
    "custom/playerctl": {
      "format": " 󰐊 {} ",
      "return-type": "json",
      "max-length": 40,
      "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}} - {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}} : {{artist}} - {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
      "on-click": "playerctl play-pause"
    },
    "network": {
        "format-wifi": " {essid} ({signalStrength}%)",
        "format-ethernet": "󰈀 {ipaddr}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": " {ifname} (No IP)",
        "format-disconnected": " Disconnected",
	      "on-click": "sh ~/scripts/rofi-wifi-menu/rofi-wifi-menu.sh"
    },
      "cpu": {
      "interval": 10,
	  	"format": " {usage}%",
	  	"tooltip": true
	  },
    "memory": {
      "format": "  {used:0.1f}G/{total:0.1f}G",
      "tooltip": true,
      "tooltip-format": "using {used:0.2f}G out of {total:0.2f}G"
    },
	  "temperature": {
      "interval": 10,
      "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon1/temp1_input",
      "critical-threshold": 98,
      "format-critical": " {temperatureC}",
      "format": " {temperatureC}°C"
	  },
    "clock": {
        "format": "{:%H:%M | %e %B} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    }
}